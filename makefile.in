# This makefile is auto-generated by @BY@

RELEASE ?= 0

## Path construction
WORK_DIR = @WORK_DIR@

MI_DIR = $(WORK_DIR)/mimalloc
MI_SRC_DIR = $(MI_DIR)/src
MI_INC_DIR = $(MI_DIR)/include

NC_DIR = $(WORK_DIR)/ncurses
NC_LIB_DIR = $(NC_DIR)/lib
NC_INC_DIR = $(NC_DIR)/include
NC_CONFIGURE_AC = $(NC_DIR)/configure.in
NC_CONFIGURE_SH = $(NC_DIR)/configure
NC_CONFIGURE_FLAGS = \
	--with-termlib \
	--without-cxx \
	--without-cxx-binding \
	--without-ada \
	--without-manpages \
	--without-progs \
	--without-tests
	
NC_MAKEFILE = $(NC_DIR)/Makefile
NC_TINFO = $(NC_LIB_DIR)/libtinfow.a

MUSH = $(WORK_DIR)/mush

## Binaries and flags
CD = cd
BASH = @BASH@
RM = @RM@
CC = @CC@
RANLIB = @RANLIB@
AUTORECONF = @AUTORECONF@

CC_FLAGS = -std=c17 \
	-Wall -Wextra -Werror -pedantic \
	-MMD -MP

LD_FLAGS =

AUTORECONF_FLAGS = -fi

## Sources and objects
SOURCES = \
	$(WORK_DIR)/mush.c \
	$(WORK_DIR)/mu-le.c \
	$(WORK_DIR)/mu-array.c

OBJECTS = $(SOURCES:.c=.o)
DEPENDS = $(OBJECTS:.o=.d)

MI_SOURCE = $(MI_SRC_DIR)/static.c
MI_OBJECT = $(MI_SOURCE:.c=.o)
MI_DEPEND = $(MI_OBJECT:.o=.d)
MI_CC_FLAGS = -DMI_XMALLOC=1 \
	-Wno-static-in-inline -I$(MI_INC_DIR) 

ifeq ($(RELEASE),0)
	CC_FLAGS += -g3 -O0
	MI_CC_FLAGS += -DMI_DEBUG=2
else
	CC_FLAGS += -O2 -flto=auto -DNDEBUG
	LD_FLAGS += -flto=auto
	MI_CC_FLAGS += -DMI_DEBUG=0 \
		-Wno-unused-parameter -Wno-unused-but-set-variable
endif

## Rules
.SUFFIXES: .c .o
all: $(MUSH)

$(MI_OBJECT): CC_FLAGS += $(MI_CC_FLAGS)
$(OBJECTS): CC_FLAGS += -I$(WORK_DIR) -I$(NC_INC_DIR) -I$(MI_INC_DIR)

$(NC_CONFIGURE_SH): $(NC_CONFIGURE_AC)
	$(AUTORECONF) $(AUTORECONF_FLAGS)

$(NC_MAKEFILE): $(NC_CONFIGURE_SH)
	$(CD) $(NC_DIR) && CC=$(CC) RANLIB=$(RANLIB) $(BASH) $(NC_CONFIGURE_SH) $(NC_CONFIGURE_FLAGS)

$(NC_TINFO): $(NC_MAKEFILE)
	$(MAKE) -C $(NC_DIR) libs

$(MUSH): $(OBJECTS) $(MI_OBJECT) $(NC_TINFO)
	$(CC) -o $@ $^ $(LD_FLAGS)

%.o: %.c
	$(CC) $(CC_FLAGS) -c -o $@ $<

.PHONY: clean
clean:
	$(RM) $(DEPENDS) $(OBJECTS) $(MUSH)
	$(RM) $(MI_DEPEND) $(MI_OBJECT)
	$(MAKE) -C $(NC_DIR) distclean

-include $(DEPENDS) $(MI_DEPEND)
